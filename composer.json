{
  "name": "fredbradley/filesystem-health-check",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Fred Bradley",
      "email": "code@fredbradley.co.uk",
      "role": "Developer"
    }
  ],
  "keywords": [
    "laravel",
    "health",
    "health-check",
    "spatie health",
    "spatie",
    "health check"
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "homepage": "https://github.com/fredbradley/filesystem-health-check",
  "description": "A Spatie Laravel Health Check, that checks your Laravel filesystems are connectable",
  "require": {
    "php": "^8.5",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "spatie/laravel-health": "^1.37"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0",
    "pestphp/pest-plugin-laravel": "^2.0|^3.0",
    "laravel/pint": "^1.29"
  },
  "autoload": {
    "psr-4": {
      "FredBradley\\FilesystemHealthCheck\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FredBradley\\FilesystemHealthCheck\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "./vendor/bin/pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
